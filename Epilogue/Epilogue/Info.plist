<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.readepilogue.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>epilogue</string>
			</array>
		</dict>
	</array>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.epilogue.trending.refresh</string>
	</array>
	<key>NSAppIntentsVisualIntelligenceSupported</key>
	<true/>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSSupportsLiveActivitiesFrequentUpdates</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>Epilogue uses your camera to capture quotes and text from book pages</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Epilogue uses the microphone to transcribe your thoughts during reading sessions</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Epilogue uses speech recognition to transcribe your reading notes in real time</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Epilogue accesses your photo library to save and share reading snapshots</string>
	<key>NSVisualIntelligenceUsageDescription</key>
	<string>Epilogue uses Visual Intelligence to extract quotes and text from book pages</string>
	<key>SKStoreKitVersion</key>
	<integer>2</integer>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>fetch</string>
		<string>audio</string>
	</array>
</dict>
</plist>
